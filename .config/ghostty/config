# --- Appearance ---
theme = Tomorrow Night
font-family = MesloLGS NF
font-size = 11.5
window-padding-x = 2
window-padding-y = 2

# --- Cursor (Refreshed Syntax) ---
cursor-style = block
cursor-style-blink = false

# --- Notifications ---
# This enables the system-level bridge for notifications
desktop-notifications = true

# --- Clipboard (OSC 52) ---
# Essential for your tmux-yank replacement
clipboard-read = allow
clipboard-write = allow

# --- Platform Overrides ---
# Using '?' ensures Ghostty ignores the file if it's missing on that OS
config-file = ?macos-config
config-file = ?linux-config
