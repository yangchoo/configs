# --- Appearance ---
theme = Tomorrow Night
font-family = "MesloLGS NF"
font-size = 11.5
window-padding-x = 2
window-padding-y = 2
cursor-style = block
cursor-blinking = false

# --- Mouse & Behavior ---
mouse-hide-while-typing = true
# This allows tmux to handle the clipboard via OSC 52 
# (Better than xclip for cross-platform)
clipboard-read = allow
clipboard-write = allow

# --- The "AI Notification" Feature ---
# Notifies you when a background command (like Claude) finishes
desktop-notifications = true
# Optional: Focus the window when you click the notification
window-alert-on-bell = true

# --- Keybindings ---
# Mac-specific quit/close to match your Alacritty config
keybind = cmd+q=quit
keybind = cmd+w=close_window
# Simple copy/paste for Linux/Mac consistency
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

